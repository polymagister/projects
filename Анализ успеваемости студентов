    "#### (4 балла) Задание 3. Визуализация распределения категориальных переменных\n",
    "\n",
    "# 1. matplotlib hist - race/ethnicity\n",
    "fig, ax = plt.subplots(figsize=(10, 6)) \n",
    "ax.hist(data['race/ethnicity'], bins=10, color='coral')\n",
    "ax.set_xlabel('Тип группы')\n",
    "ax.set_ylabel('Количество человек')\n",
    "ax.set_title('Распределение по этническим группам')\n",
    "\n",
    "\n",
    "# 2. seaborn countplot - gender\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.countplot(data['gender'], color='green')\n",
    "plt.title('Распределение по полу')\n",
    "plt.xlabel('Количество студентов')\n",
    "plt.ylabel('Пол')\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# 3. plotly pie - parental level of education\n",
    "fig = px.pie(data, names='parental level of education', title='Уровень образования родителей')\n",
    "fig.show()\n",
    "\n",
    "\n",
    "# 4. barh - lunch\n",
    "plt.figure(figsize=(8, 6))\n",
    "lunch_counts = data['lunch'].value_counts()\n",
    "plt.barh(lunch_counts.index, lunch_counts.values, color='skyblue')\n",
    "plt.title('Распределение по типу ланча')\n",
    "plt.xlabel('Количество студентов')\n",
    "plt.ylabel('Тип ланча')\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# 5. Countplot - test preparation course\n",
    "plt.figure(figsize=(8, 6))\n",
    "data['test preparation course'].value_counts().plot(kind='bar', color='orange')\n",
    "plt.title('Распределение по подготовительному курсу')\n",
    "plt.xlabel('не завершил или завершил курс')\n",
    "plt.ylabel('Количество человек')\n",
    "plt.show()"
   ]
  },
