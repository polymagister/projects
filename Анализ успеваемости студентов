    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "\n",
    "# Для первой гипотезы (seaborn, kdepolot)\n",
    "ax.hist(data['writing score'], bins=30, color='green', edgecolor='black',\n",
    "        alpha=0.4, density=True, label='Writing Score')\n",
    "\n",
    "# KDE поверх, чтобы видно было\n",
    "sns.kdeplot(data['reading score'], color='coral', linewidth=2, label='Reading Score', ax=ax)\n",
    "\n",
    "ax.set_xlabel('Оценка')\n",
    "ax.set_ylabel('Плотность')\n",
    "plt.title('1 Зависимость между Writing и Reading Score')\n",
    "plt.legend()\n",
    "plt.show()\n",
    "\n",
    "# Для второй гипотезы на plotly\n",
    "education_means = data.groupby('parental level of education')['math score'].mean().reset_index()\n",
    "fig = px.line(education_means, x='parental level of education', y='math score', \n",
    "              markers=True, title='2. Зависимость оценок от образования родителей')\n",
    "fig.show()\n",
    "\n",
    "# Третья гипотеза на matplotlib (Выбрано 4 случая, из комбинации ланча и окончания курса)\n",
    "plt.figure(figsize=(8, 6))\n",
    "data.groupby(['lunch', 'test preparation course'])['math score'].mean().plot(kind='bar')\n",
    "plt.xlabel('Ланч, Курс')\n",
    "plt.ylabel('Средняя оценка по математике')\n",
    "plt.title('3. Влияние ланча и курса на математику')\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()"
